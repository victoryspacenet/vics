{
  "name": "vics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:netlify": "npm run install:netlify && netlify dev",
    "install:netlify": "npm install --prefix netlify --omit=dev",
    "netlify:push-openai": "node scripts/netlify-push-openai.cjs",
    "build": "npm run install:netlify && vite build && node scripts/copy-404.js",
    "build:mobile": "npm run build && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@capacitor/push-notifications": "^7.0.6",
    "@capacitor/share": "^7.0.4",
    "@supabase/supabase-js": "^2.106.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.576.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^7.2.2"
  }
