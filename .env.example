VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 로컬: 마일스톤 Gate가 실제 Clap과 와이어 Clap(1245) 중 큰 값으로 팝업 조건을 판정합니다. 수령 버튼은 DB Clap 수를 검사하므로 실제 미달이면 RPC가 거절될 수 있어요.
# VITE_FANDOM_UI_DEMO=true

# 로컬 테스트: 포인트가 스포트라이트 구매료(5,000P) 미만일 때만 VITE_BOOST_POINTS_FLOOR 로 올림 (차감 후 잔액은 덮어쓰지 않음).
# npm run dev 시 .env.development 에서 기본 켜져 있을 수 있음. 끄려면 VITE_BOOST_POINTS_FOR_TEST 삭제 또는 0.
# VITE_BOOST_POINTS_FOR_TEST=1
# VITE_BOOST_POINTS_FLOOR=50000

# (개발 전용) npm run dev 시 해당 닉네임이면 fandom_tier를 UI에서 다이아로 취급 — 운영 빌드에는 넣지 마세요.
# VITE_DEV_FANDOM_TIER_AS_DIAMOND_FOR_NICKNAME=테스트닉네임

# 관리자 이메일 (쉼표 구분, 해당 이메일로 로그인한 사용자만 관리자로 인정)
# VITE_ADMIN_EMAILS=admin@example.com,dev@example.com
# 운영자 이메일 (쉼표 구분, 관리자 페이지 GNB·접근 허용. 관리자 목록과 합쳐서 권한 부여)
# VITE_OPERATOR_EMAILS=operator@example.com

# 카카오 JavaScript 키 (선택) — 매치업 상세 SNS 공유 시 카카오톡 피드 공유. 미설정 시 Web Share API 또는 링크 복사
# https://developers.kakao.com → 앱 → 앱 키 → JavaScript 키
# VITE_KAKAO_JS_KEY=

# ── Netlify(서버 전용, 대시보드에만 설정. Vite .env에 넣지 마세요) ──
# 1:1 문의 답변 시 수신자 이메일 발송: inquiry-reply-email 함수
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM=noreply@yourdomain.com
# ADMIN_EMAILS=admin@example.com
# OPERATOR_EMAILS=operator@example.com
