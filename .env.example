# =============================================================================
# 로컬: 이 파일을 복사해 `.env.local` 을 만든 뒤 아래 값을 채우세요.
#   Windows: copy .env.example .env.local
#   Mac/Linux: cp .env.example .env.local
#   `.env` / `.env.local` / `.env.production` 은 .gitignore 로 커밋되지 않습니다.
#
# 배포(Netlify): 저장소의 .env.local 을 읽지 않습니다.
#   Netlify → Project configuration → Environment variables 에
#   아래와 동일한 변수명(반드시 VITE_ 접두사 포함)으로 같은 Supabase 값을 넣으세요.
#   그래야 로컬에서 가입한 유저가 배포 관리자 목록에도 보입니다.
#   체크리스트: docs/DEPLOYMENT_ENV.md
# =============================================================================

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# (선택) Supabase Edge: matchup-media 검증 업로드 URL 전체
# 예: https://<project-ref>.supabase.co/functions/v1/matchup-media-upload
# Edge 함수 시크릿에 SUPABASE_SERVICE_ROLE_KEY 추가 필요
# 기본은 Storage 직접 업로드(안정). Edge를 먼저 쓰려면 URL과 함께 VITE_MATCHUP_MEDIA_UPLOAD_EDGE_FIRST=1
# VITE_MATCHUP_MEDIA_UPLOAD_URL=

# Capacitor / 네이티브 앱 빌드 시 권장: Netlify(또는 정적 호스팅) 프로덕션 절대 URL (끝에 / 없이).
# 설정 시 /api/* Netlify Functions 호출이 이 주소로 붙습니다. 웹만 쓸 때는 비워도 됩니다.
# 스토어용 프로덕션 빌드: 루트에 `.env.production`을 두는 방식이 일반적입니다. 예시는 `.env.production.example` 참고.
# VITE_SITE_ORIGIN=https://your-site.netlify.app
# npm run dev 중에는 OAuth redirect 가 항상 **현재 탭 origin**(localhost·127.0.0.1·LAN IP 등)을 씁니다.
# VITE_SITE_ORIGIN 을 운영 URL로 두어도 로그인 뒤 프로덕션으로 튕기지 않도록 맞춰 두었습니다.
# 위 변수는 Capacitor·프로덕션 빌드·resolveSiteUrl 의 절대 API 경로 등에서 쓰입니다.
# Supabase 대시보드 → Authentication → URL Configuration:
#   Redirect URLs 에 http://localhost:5173/** , http://127.0.0.1:5173/** , http://localhost:5173/reset-password (포트 맞게) 추가
#   비밀번호 재설정: 클라이언트는 implicit 플로우(flowType, supabase.js)로 메일 링크를 처리합니다.
#   크롬/엣지·메일앱처럼 링크를 여는 브라우저가 달라도 동작합니다(PKCE는 요청했던 브라우저와 같아야 해서 깨지기 쉬움).
#   Site URL 은 배포 도메인 또는 로컬 테스트 시 http://localhost:5173

# 로컬: 마일스톤 Gate가 실제 Clap과 와이어 Clap(1245) 중 큰 값으로 팝업 조건을 판정합니다. 수령 버튼은 DB Clap 수를 검사하므로 실제 미달이면 RPC가 거절될 수 있어요.
# VITE_FANDOM_UI_DEMO=true

# 로컬 테스트: 포인트가 스포트라이트 구매료(5,000P) 미만일 때만 VITE_BOOST_POINTS_FLOOR 로 올림 (차감 후 잔액은 덮어쓰지 않음).
# npm run dev 시 .env.development 에서 기본 켜져 있을 수 있음. 끄려면 VITE_BOOST_POINTS_FOR_TEST 삭제 또는 0.
# VITE_BOOST_POINTS_FOR_TEST=1
# VITE_BOOST_POINTS_FLOOR=50000
#
# 로컬 QA: 닉네임 일치 시 리워드 구매·보유 포인트를 UI에서 0으로 표시 (npm run dev 전용).
# VITE_DEV_RESET_PURCHASES_FOR_NICKNAME=테스트닉네임

# (개발 전용) npm run dev 시 해당 닉네임이면 fandom_tier를 UI에서 다이아로 취급 — 운영 빌드에는 넣지 마세요.
# VITE_DEV_FANDOM_TIER_AS_DIAMOND_FOR_NICKNAME=테스트닉네임

# 관리자 이메일 (쉼표 구분, 해당 이메일로 로그인한 사용자만 관리자로 인정)
# VITE_ADMIN_EMAILS=admin@example.com,dev@example.com
# 운영자 이메일 (쉼표 구분, 관리자 페이지 GNB·접근 허용. 관리자 목록과 합쳐서 권한 부여)
# VITE_OPERATOR_EMAILS=operator@example.com

# Google Analytics 4 (선택) — victoryspace.net 트래픽·페이지뷰 수집
# Google Analytics → 관리 → 데이터 스트림 → 웹 → 측정 ID (G-XXXXXXXXXX)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# 로컬 npm run dev 에서도 수집하려면 VITE_GA_ENABLE_DEV=1 (기본: 프로덕션만)

# HubSpot (선택) — 설정 → 추적 코드 → js.hs-scripts.com/ 뒤 숫자(포털 ID)
# VITE_HUBSPOT_PORTAL_ID=12345678
# 로컬에서 HubSpot 테스트: VITE_HUBSPOT_ENABLE_DEV=1

# 카카오 JavaScript 키 (선택) — 매치업 상세 SNS 공유 시 카카오톡 피드 공유
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# VITE_KAKAO_JS_KEY=
#
# 4019 오류 — 아래 두 곳 모두 등록 필요 (제품 링크만 등록하면 4019 계속 발생):
# 1) [앱] → [플랫폼 키] → [JavaScript 키] → JavaScript SDK 도메인
#    예: http://localhost:5173 , http://127.0.0.1:5173 , https://www.victoryspace.net
# 2) [앱] → [제품 링크 관리] → 웹 도메인 (공유 메시지 안 링크용)
#    예: https://www.victoryspace.net
#
# 4011 오류 — 도메인 등록과 별개로 "앱 키 자체"가 틀릴 때 발생:
# - REST API 키·네이티브 앱 키를 넣으면 4011 (반드시 JavaScript 키)
# - JavaScript 키가 여러 개면, localhost를 등록한 **그 줄의 키**를 복사해야 함
# - 카카오 로그인(Supabase)용 REST API 키 ≠ 공유용 JavaScript 키
# - 키 변경 후: .env.local 저장 → npm run dev 재시작 (Netlify는 재배포)
# Netlify: VITE_SITE_ORIGIN 과 동일 도메인을 카카오에 등록하세요.
# SDK를 쓸 hostname (쉼표 구분, www·비-www 둘 다 필요하면 둘 다):
# VITE_KAKAO_SDK_DOMAINS=www.victoryspace.net,victoryspace.net,localhost
#
# Capacitor 앱: WebView origin(https://localhost)은 카카오 JS SDK 도메인 등록 불가 →
# 앱에서는 @capacitor/share 네이티브 공유 시트(카카오톡 선택)를 사용합니다. JS SDK는 웹 전용.
# localhost dev(npm run dev): JS SDK 공유창 사용 가능 — 아래 도메인 등록 필수:
#   http://localhost:5173  (JavaScript SDK 도메인)
#   https://www.victoryspace.net  (제품 링크 관리 + 공유 링크용 VITE_SITE_ORIGIN)

# 로컬: .env.development 에 VITE_MATCHUP_SIMILARITY_FAIL_OPEN=1 이 기본 포함됨(npm run dev).
# 원격 검사만 쓰려면 해당 줄을 지우고 아래만 설정해 배포 URL로 호출.
# VITE_MATCHUP_CHALLENGE_SIMILARITY_URL=https://your-site.netlify.app/api/matchup-challenge-similarity
# 클라이언트 → 유사도 API fetch 타임아웃(ms). 초과 시 fail-open이면 검사 생략, 아니면 오류.
# VITE_MATCHUP_SIMILARITY_TIMEOUT_MS=28000
# 로컬에서 Netlify 함수까지 띄우려면: npm run dev:netlify
#
# OpenAI 키를 Netlify에 올리기(저장소에 키 커밋 금지): 루트에 .env 또는 .env.local 에 OPENAI_API_KEY=sk-... 후
# npm run netlify:push-openai
#
# 매치업 신고 자동 몰수패(Netlify) — SUPABASE_SERVICE_ROLE_KEY 필수, OPENAI_API_KEY 권장
# MATCHUP_RIGHT_REPORTS_FORFEIT_MIN=5
# MATCHUP_MODERATION_CONFIDENCE_MIN=55
# VITE_MATCHUP_REPORT_MODERATION_URL= (선택) 배포 URL
# VITE_MATCHUP_MODERATION_FAIL_OPEN=1  (로컬 Vite만 쓸 때 /api 없음 폴백)

# ── Netlify(서버 전용, 대시보드에만 설정. Vite .env에 넣지 마세요) ──
# 도전자 업로드 시 A측과 주제 유사도(OpenAI 멀티모달). 미설정 시 검사 생략(통과)
# OPENAI_API_KEY=
# OPENAI_SIMILARITY_MODEL=gpt-4o-mini
# MATCHUP_CHALLENGE_SIMILARITY_MIN=32
# OpenAI HTTP 타임아웃(ms). 초과 시 require_ai가 아니면 fail_open과 동일하게 스킵 처리됨
# MATCHUP_SIMILARITY_OPENAI_TIMEOUT_MS=20000
# OpenAI 오류 시에도 업로드 허용(기본: 거부)
# MATCHUP_SIMILARITY_FAIL_OPEN=1
# OPENAI 키 없을 때 업로드 거부(엄격 모드)
# MATCHUP_SIMILARITY_REQUIRE_AI=1
# 1:1 문의 답변 시 수신자 이메일 발송: inquiry-reply-email 함수
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM=noreply@yourdomain.com
# ADMIN_EMAILS=admin@example.com
# OPERATOR_EMAILS=operator@example.com
