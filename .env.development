# Vite 개발 서버(npm run dev)에서만 로드됩니다.
#
# =============================================================================
# Supabase — 배포(Netlify)와 같은 키 이름으로 맞추기
# -----------------------------------------------------------------------------
# 비밀 값은 이 파일에 넣지 마세요. 루트 `.env.local`(또는 `.env`)에만 두세요(.gitignore).
# Netlify → Project / Site configuration → Environment variables 에도 아래와
# 동일한 변수명으로 등록하고, 로컬과 같은 Supabase 프로젝트를 가리키면
# 회원가입·관리자 유저 목록이 같은 DB를 봅니다.
#
#   VITE_SUPABASE_URL=https://<project-ref>.supabase.co
#   VITE_SUPABASE_ANON_KEY=<anon public key>
#   (권장) VITE_SITE_ORIGIN=http://localhost:5173
#
# Vite는 개발 모드에서 `.env.development` + `.env.local`을 모두 읽으며,
# 겹치는 키는 `.env.local`이 우선합니다. 절차·표: docs/DEPLOYMENT_ENV.md
# =============================================================================
#
# 매치업 도전 유사도 API(/api/matchup-challenge-similarity)는 Vite 단독 실행 시 없음 → 아래로 404 시 검사 생략.
# 로컬에서 실제 검사를 쓰려면: (1) npm run dev:netlify 또는 (2) 배포 URL을 지정해 원격 함수 호출.
VITE_MATCHUP_SIMILARITY_FAIL_OPEN=1
# 배포 사이트 함수로 유사도 검사 — Netlify에 OPENAI_API_KEY 등록 후 사용(npm run netlify:push-openai)
VITE_MATCHUP_CHALLENGE_SIMILARITY_URL=https://www.victoryspace.net/api/matchup-challenge-similarity
#
# 매치업 작성(A) 카테고리·콘텐츠 유사도 API(/api/matchup-category-similarity) — 위와 동일 이유로 로컬 기본 fail-open.
VITE_MATCHUP_CATEGORY_SIMILARITY_FAIL_OPEN=1
VITE_MATCHUP_CATEGORY_SIMILARITY_URL=https://www.victoryspace.net/api/matchup-category-similarity
#
# 포인트가 5,000P 미만일 때만 아래 최소값으로 올림(구매 후 차감 잔액은 유지). 스포트라이트 구매 테스트용.
# 운영 빌드에는 포함되지 않습니다. 원치 않으면 VITE_BOOST_POINTS_FOR_TEST 를 지우거나 0으로 두세요.
VITE_BOOST_POINTS_FOR_TEST=
VITE_BOOST_POINTS_FLOOR=

# 로컬에서만: 아래 닉네임과 일치하면 프로필 fetch 시 fandom_tier를 UI상 다이아로 간주(레전드 테마 등 QA).
# 실제 DB 등급은 supabase_seed_mutjangi_fandom_diamond.sql 로 맞추는 것을 권장합니다.
VITE_DEV_FANDOM_TIER_AS_DIAMOND_FOR_NICKNAME=

# 로컬에서만: 아래 닉네임과 일치하면 가상 구매·보유 포인트(0P 표시)를 UI에서 초기화하고 티어 보너스 자동 지급을 건너뜀.
# DB 영구 반영은 supabase_reset_test_account_virtual_points.sql 실행.
VITE_DEV_RESET_PURCHASES_FOR_NICKNAME=멋쟁이해병
